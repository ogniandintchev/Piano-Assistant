// Note number is implicit to index of NoteInterval in song array
struct Interval {

    let noteOn : number // Could be a measure of time, an X coordinate, whatever
    let noteOff : number
    let durationPlayed : number // 0-100 or 0-1 just something to get a total played amount
    
}

// All intervals of a given note, intervals of C or D etc.
struct NoteInterval {

    let cursor : number // Once an interval is completely past, increment the curor so the next note could only be the earliest
    let intervals : Interval[]
    let wrongIntervals : Interval[] // Any time period where it doesn't overlap with interval or its buffer goes here
    // Wrong notes will go into their respective NoteInterval.wrongIntervals to be handled later

    

}

struct Song {

    noteIntervals : NoteInterval[127] // Correct note intervals, size being # of possible midi notes,

}



